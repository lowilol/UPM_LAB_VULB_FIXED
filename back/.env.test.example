# Overrides opcionales para las pruebas de caja negra del back.
# Copia este fichero a back/.env.test si necesitas cambiar valores por defecto.
# Los secretos (ACCESS_TOKEN_SECRET, RESET_PASSWORD_TOKEN) y la conexión a BD
# se leen de ../.env (el mismo que usa el servidor); aquí solo van overrides.

# URL del backend bajo prueba
API_BASE_URL=http://127.0.0.1:4000

# Puertos/host opcionales si difieren de los del servidor
# DB_PORT=3306
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Dominios institucionales usados para el alta por rol
TEST_EMAIL_DOMAIN_ALUMNO=@alumnos.upm.es
TEST_EMAIL_DOMAIN_PROFESOR=@upm.es
